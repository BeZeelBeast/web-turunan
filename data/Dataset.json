  "konsep_dasar": {
    "definisi": {
      "teks": "Turunan suatu fungsi f(x) di titik x adalah limit dari perbandingan perubahan nilai fungsi terhadap perubahan variabelnya ketika perubahan tersebut mendekati nol.",
      "rumus_limit": "f'(x) = lim[h→0] (f(x+h) − f(x)) ⁄ h",
      "rumus_titik": "f'(a) = lim[x→a] (f(x) − f(a)) ⁄ (x − a)"
    },
    "interpretasi_geometri": {
      "teks": "Secara geometri, turunan f'(a) menyatakan gradien (kemiringan) garis singgung kurva y = f(x) di titik (a, f(a)).",

  "contoh_soal": [
    {
      "id": "S01",
      "level": "dasar",
      "topik": "Aturan Pangkat",
      "soal": "Tentukan turunan dari f(x) = 3x⁴ - 7x² + 5x - 2",
      "langkah": [
        "Gunakan aturan pangkat: d⁄dx[xⁿ] = n·xⁿ-¹",
        "Turunkan tiap suku secara terpisah",
        "f'(x) = 4·3x³ - 2·7x + 5 - 0",
        "f'(x) = 12x³ - 14x + 5"
      ],
      "jawaban": "f'(x) = 12x³ - 14x + 5"
    },
    {
      "id": "S02",
      "level": "dasar",
      "topik": "Turunan Trigonometri",
      "soal": "Tentukan turunan dari f(x) = 3sin(x) - 2cos(x) + tan(x)",
      "langkah": [
        "d⁄dx[sin x] = cos x",
        "d⁄dx[cos x] = -sin x",
        "d⁄dx[tan x] = sec²x",
        "f'(x) = 3cos(x) - 2(-sin x) + sec²x",
        "f'(x) = 3cos(x) + 2sin(x) + sec²x"
      ],
      "jawaban": "f'(x) = 3cos(x) + 2sin(x) + sec²(x)"
    },
    {
      "id": "S03",
      "level": "dasar",
      "topik": "Turunan Eksponen & Logaritma",
      "soal": "Tentukan turunan dari f(x) = 5eˣ + 3ln(x)",
      "langkah": [
        "d⁄dx[eˣ] = eˣ",
        "d⁄dx[ln x] = 1⁄x",
        "f'(x) = 5eˣ + 3·(1⁄x)"
      ],
      "jawaban": "f′(x) = 5eˣ + 3⁄x"
    },
    {
      "id": "S04",
      "level": "menengah",
      "topik": "Product Rule",
      "soal": "Tentukan turunan dari f(x) = (2x² + 1)(3x - 4)",
      "langkah": [
        "Misalkan u = 2x² + 1  dan  v = 3x - 4",
        "u' = 4x ,  v' = 3",
        "f'(x) = u'v + uv'",
        "f'(x) = 4x(3x-4) + (2x²+1)(3)",
        "f'(x) = 12x² - 16x + 6x² + 3",
        "f'(x) = 18x² - 16x + 3"
      ],
      "jawaban": "f'(x) = 18x² - 16x + 3"
    },
    {
      "id": "S05",
      "level": "menengah",
      "topik": "Quotient Rule",
      "soal": "Tentukan turunan dari f(x) = (x² + 1) ⁄ (x − 1)",
      "langkah": [
        "Misalkan u = x² + 1,  v = x - 1",
        "u' = 2x ,  v' = 1",
        "f′(x) = (u′v − uv′) ⁄ v²",
        "f′(x) = (2x(x−1) − (x²+1)·1) ⁄ (x−1)²",
        "f′(x) = (2x² − 2x − x² − 1) ⁄ (x−1)²",
        "f′(x) = (x² − 2x − 1) ⁄ (x−1)²"
      ],
      "jawaban": "f′(x) = (x² − 2x − 1) ⁄ (x−1)²"
    },
    {
      "id": "S06",
      "level": "menengah",
      "topik": "Chain Rule",
      "soal": "Tentukan turunan dari f(x) = (3x² + 2)⁵",
      "langkah": [
        "Misalkan u = 3x² + 2  →  f(x) = u⁵",
        "du⁄dx = 6x",
        "df⁄du = 5u⁴",
        "f'(x) = 5u⁴ · 6x",
        "f'(x) = 30x(3x² + 2)⁴"
      ],
      "jawaban": "f'(x) = 30x(3x² + 2)⁴"
    },
    {
      "id": "S07",
      "level": "aplikasi",
      "topik": "Kecepatan & Percepatan",
      "soal": "Sebuah benda bergerak dengan posisi s(t) = t³ - 6t² + 9t + 2 (meter, t dalam detik). Tentukan: a) kecepatan v(t), b) percepatan a(t), c) kecepatan pada t = 2",
      "langkah": [
        "a) v(t) = s'(t) = 3t² - 12t + 9",
        "b) a(t) = v'(t) = s''(t) = 6t - 12",
        "c) v(2) = 3(4) - 12(2) + 9 = 12 - 24 + 9 = -3 m/s",
        "Tanda negatif: benda bergerak mundur saat t = 2"
      ],
      "jawaban": {
        "v_t": "3t² - 12t + 9",
        "a_t": "6t - 12",
        "v_at_t2": "-3 m/s"
      }
    },
    {
      "id": "S08",
      "level": "aplikasi",
      "topik": "Nilai Maksimum & Minimum",
      "soal": "Tentukan nilai maksimum dan minimum lokal dari f(x) = x³ - 3x² - 9x + 5",
      "langkah": [
        "f'(x) = 3x² - 6x - 9 = 0",
        "3(x² - 2x - 3) = 0",
        "3(x-3)(x+1) = 0  →  x = 3 atau x = -1",
        "f''(x) = 6x - 6",
        "f''(-1) = -12 < 0  →  x = -1 adalah maksimum lokal",
        "f''(3) = 12 > 0   →  x = 3 adalah minimum lokal",
        "f(-1) = -1 - 3 + 9 + 5 = 10  (nilai maksimum lokal)",
        "f(3) = 27 - 27 - 27 + 5 = -22 (nilai minimum lokal)"
      ],
      "jawaban": {
        "maksimum_lokal": {
          "x": -1,
          "nilai": 10
        },
        "minimum_lokal": {
          "x": 3,
          "nilai": -22
        }
      }
    }
  ],
